import 'wezterm'

if builder = wezterm.config_builder
  _G._module_0 = builder

fira_code =
  family: 'Fira Code'
  harfbuzz_features:
    * 'ss01'
    * 'ss06'
    * 'ss07'
    * 'zero'
    * 'ss09'
    * 'ss19'
    * 'onum'
    * 'ss20'
    * 'cv14'
    * 'cv25'
    * 'cv26'
    * 'cv27'

export font_size = switch wezterm.hostname!
  when 'glowworm'
    14
  else
    18

export line_height = 1.2
export font = wezterm.font_with_fallback
  * fira_code
  * family: 'Noto Color Emoji'
export font_rules =
  * italic: true
    font: wezterm.font_with_fallback {
      {
        family: 'Script12 BT'
        italic: false
        harfbuzz_features:
          * 'calt'
          * 'clig'
      }
      'Fira Code iScript'
      fira_code
      'Noto Color Emoji'
    }

export hide_mouse_cursor_when_typing = true
export hide_tab_bar_if_only_one_tab = true
export window_decorations = 'RESIZE' -- 'NONE' -- 'TITLE|RESIZE'
export max_fps = 144

opacities =
  * 0.0
  * 0.4
  * 0.6
  * 0.9
  * 1.0
curr_opacity_idx = 4
export window_background_opacity = opacities[curr_opacity_idx]
-- export window_background_opacity = 0.4
-- Latte Frappe Macchiato Mocha
export color_scheme = 'Catppuccin Mocha' -- Google Dark (Gogh)' -- 'Gruvbox Material (Gogh)' -- 'Adventure' 'Andromeda' 'Apple Classic' 'Gigavolt' 'Google Dark (Gogh)' 'Green Screen' 'Gruber'

