--   window\set_config_overrides overrides

export default_cursor_style = "BlinkingBlock"
export cursor_blink_rate = 500
export cursor_blink_ease_in = 'EaseIn'
export cursor_blink_ease_out = 'Constant'
export force_reverse_video_cursor = true

export warn_about_missing_glyphs = false

export keys =
  * key: 'r'
    mods: 'CTRL|SHIFT'
    action: wezterm.action.ReloadConfiguration
  * key: '}'
    mods: 'CTRL|SHIFT'
    action: wezterm.action_callback (win, pane) ->
      win\set_config_overrides with win\get_config_overrides! ?? {}
        curr_opacity_idx += 1
        if curr_opacity_idx > #opacities
          curr_opacity_idx = #opacities
        .window_background_opacity = opacities[curr_opacity_idx]
  * key: '{'
    mods: 'CTRL|SHIFT'
    action: wezterm.action_callback (win, pane) ->
      win\set_config_overrides with win\get_config_overrides! ?? {}
        curr_opacity_idx -= 1
        if curr_opacity_idx < 1
          curr_opacity_idx = 1
        .window_background_opacity = opacities[curr_opacity_idx]
  -- * key: "~"
  --   mods: 'CTRL|SHIFT'
  --   action: wezterm.action_callback (win, pane) ->
  --     win\set_config_overrides with win\get_config_overrides! ?? {}
  --       .color_scheme = if .color_scheme == 'x'
  --         'Catppuccin Mocha'
  --       else
  --         'Catppuccin Latte'
  -- * key: 'p'
  --   mods: 'CTRL|SHIFT'
  --   action: wezterm.action_callback (win, pane) ->
  --     win\set_config_overrides with win\get_config_overrides! ?? {}
  --       .window_decorations = if .window_decorations == 'NONE'
  --         'TITLE|RESIZE'
  --       else
  --         'NONE'
  --       window\toast_notification 'a'
  --       curr_opacity_idx = 1
  --       .window_background_opacity = opacities[curr_opacity_idx]

if DEBUG
  wezterm.on 'window-config-reloaded', (window, pane) ->
    if window\is_focused!
      window\toast_notification 'wezterm', 'config reloaded', nil, 4000
