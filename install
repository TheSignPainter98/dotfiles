#!/usr/bin/python3

import hashlib
import os
import subprocess
import shlex
import sqlite3

DRY_RUN = False

VERSION = 3
SCHEMA = f'''
    PRAGMA user_version = {VERSION};
    PRAGMA writable_schema = 0;

    CREATE TABLE step (
        id INTEGER PRIMARY KEY,
        name TEXT NOT NULL UNIQUE,
        priority INTEGER NOT NULL,
        hash TEXT NOT NULL,

        status INTEGER NOT NULL
            DEFAULT 0
            CHECK (0 <= status AND status <= 2),
        pretty_status TEXT AS (CASE
            WHEN status = 0 THEN 'not-started'
            WHEN status = 1 THEN 'in-progress'
            WHEN status = 2 THEN 'complete'
            ELSE 'unknown'
        END)
    ) STRICT;
'''

class Command:
    def __init__(self, name, command, priority, pre_install=None, post_install=None, rollback_command=None, pre_rollback=None, post_rollback=None):
        if pre_install is not None and type(pre_install) is not list:
            pre_install = [pre_install]
        if post_install is not None and type(post_install) is not list:
            post_install = [post_install]
        if pre_rollback is not None and type(pre_rollback) is not list:
            pre_rollback = [pre_rollback]
        if post_rollback is not None and type(post_rollback) is not list:
            post_rollback = [post_rollback]

        self.name = name
        self.command = command
        self.priority = priority
        self.rollback_command = rollback_command
        self.pre_install = pre_install
        self.post_install = post_install
        self.pre_rollback = pre_rollback
        self.post_rollback = post_rollback

        hasher = hashlib.sha256()
        def update_hash(command):
            if command is None:
                hasher.update(b'')
                return
            hasher.update(hash(tuple(command)).to_bytes(8, 'little', signed=True))
        update_hash(command)
        update_hash(rollback_command)
        update_hash(pre_install)
        update_hash(post_install)
        update_hash(pre_rollback)
        update_hash(post_rollback)
        self.hash = hasher.hexdigest()

    def declare(self, cursor):
        cursor.execute(
            '''
                INSERT OR IGNORE
                INTO step (name, priority, hash)
                VALUES (?, ?, ?)
            ''',
            (self.name, self.priority, self.hash),
        )

    def enact(self, conn):
        self.record_status(conn, 'in-progress')

        if self.pre_install is not None:
            for command in self.pre_install:
                if type(command) is str:
                    command = shlex.split(command)
                if type(command) is System:
                    command.run()
                else:
                    self.execute(command)

        self.execute(self.command)

        if self.post_install is not None:
            for command in self.post_install:
                if type(command) is str:
                    command = shlex.split(command)
                if type(command) is System:
                    command.run()
                else:
                    self.execute(command)

        self.record_status(conn, 'complete')

    def rollback(self, conn):
        if self.rollback_command is None:
            raise Exception(f'cannot rollback {self.command}')

        if self.pre_rollback is not None:
            for command in self.pre_rollback:
                if type(command) is str:
                    command = shlex.split(command)
                if type(command) is System:
                    command.run()
                else:
                    self.execute(command)

        self.execute(self.rollback_command)

        if self.post_rollback is not None:
            for command in self.post_rollback:
                if type(command) is str:
                    command = shlex.split(command)
                if type(command) is System:
                    command.run()
                else:
                    self.execute(command)

        self.record_status(conn, 'not-started')

    def execute(self, command):
        print(f'$ {' '.join(command)}')
        if DRY_RUN:
            return
        subprocess.run(command).check_returncode()

    def record_status(self, conn, status):
        statuses = {
            'not-started': 0,
            'in-progress': 1,
            'complete': 2,
        }
        status = statuses[status]
        try:
            cursor = conn.cursor()
            cursor.execute('BEGIN IMMEDIATE')
            cursor.execute(
                '''
                    UPDATE step
                    SET status = ?
                    WHERE name = ?
                ''',
                (status, self.name)
            )
            cursor.execute('COMMIT')
        except Exception as ex:
            cursor.execute('ROLLBACK')
            raise ex

PRIORITY_PRE = -99999
PRIORITY_POST = 99999

PRIORITY_APT = 0 * 8
def apt(name, **kwargs):
    return Command(
        name,
        ['sudo', 'apt', 'install', '-y', name],
        PRIORITY_APT,
        rollback_command=['sudo', 'apt', 'remove', '-y', name],
        **kwargs,
    )

PRIORITY_SNAP = 1 * 8
def snap(name, **kwargs):
    return Command(
        name,
        ['sudo', 'snap', 'install', name],
        PRIORITY_SNAP,
        rollback_command=['sudo', 'snap', 'remove', '--purge', name],
        **kwargs
    )

PRIORITY_CLASSIC_SNAP = 2 * 8
def classic_snap(name, **kwargs):
    return Command(
        name,
        ['sudo', 'snap', 'install', '--classic', name],
        PRIORITY_CLASSIC_SNAP,
        rollback_command=['sudo', 'snap', 'remove', '--purge', name],
        **kwargs
    )

PRIORITY_CARGO = 3 * 8
def cargo(name, **kwargs):
    return Command(
        name,
        ['cargo', 'install', '--locked', name],
        PRIORITY_CARGO,
        rollback_command=['cargo', 'uninstall', name],
        **kwargs
    )

PRIORITY_DOTDIR = 4 * 8
def dotdir(dir, **kwargs):
    source_dir = os.path.abspath(f'./home/{dir}')
    absdir = os.path.expanduser(f'~/{dir}')
    return Command(
        dir,
        ['ln', '-fs', source_dir, absdir],
        PRIORITY_DOTDIR,
        **kwargs,
    )

PRIORITY_DOTFILE = 5 * 8
def dotfile(file, source_file=None, **kwargs):
    if source_file is None:
        source_file = os.path.abspath(f'./home/{file}')
    absfile = os.path.expanduser(f'~/{file}')
    return Command(
        file,
        ['ln', '-fs', source_file, absfile],
        PRIORITY_DOTFILE,
        **kwargs,
    )

def main():
    tasks = all_tasks()
    conn = ensure_setup('dotfiles.db', tasks)
    cursor = conn.cursor()

    tasks_by_name = { task.name: task for task in tasks }

    to_rollback_query = cursor.execute('''
        SELECT name
        FROM step
        WHERE status = 1
        ORDER BY
            priority ASC,
            name ASC
    ''')
    to_rollback = [ tasks_by_name[name] for (name,) in to_rollback_query ]
    for task in to_rollback:
        task.rollback(conn)

    to_enact_query = cursor.execute('''
        SELECT name
        FROM step
        WHERE status = 0
        ORDER BY
            priority ASC,
            name ASC
    ''')
    to_enact = [ tasks_by_name[name] for (name,) in to_enact_query ]
    for task in to_enact:
        task.enact(conn)

