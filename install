#!/usr/bin/python3

import copy
import hashlib
import os
import shlex
import socket
import sqlite3
import subprocess
from pathlib import Path

DRY_RUN = False

VERSION = 4
SCHEMA = f'''
    PRAGMA user_version = {VERSION};
    PRAGMA writable_schema = 0;

    CREATE TABLE machine_info (
        key TEXT NOT NULL UNIQUE,
        value ANY
    ) STRICT;

    CREATE TABLE step (
        id INTEGER PRIMARY KEY,
        name TEXT NOT NULL UNIQUE,
        priority INTEGER NOT NULL,
        hash TEXT NOT NULL,

        status INTEGER NOT NULL
            DEFAULT 0
            CHECK (0 <= status AND status <= 2),
        pretty_status TEXT AS (CASE
            WHEN status = 0 THEN 'not-started'
            WHEN status = 1 THEN 'in-progress'
            WHEN status = 2 THEN 'complete'
            ELSE 'unknown'
        END)
    ) STRICT;
'''

class Command:
    def __init__(self, name, command, priority, pre_install=None, post_install=None, rollback_command=None, pre_rollback=None, post_rollback=None):
        if pre_install is not None and type(pre_install) is not list:
            pre_install = [pre_install]
        if post_install is not None and type(post_install) is not list:
            post_install = [post_install]
        if pre_rollback is not None and type(pre_rollback) is not list:
            pre_rollback = [pre_rollback]
        if post_rollback is not None and type(post_rollback) is not list:
            post_rollback = [post_rollback]

        self.name = name
        self.command = command
        self.priority = priority
        self.rollback_command = rollback_command
        self.pre_install = pre_install
        self.post_install = post_install
        self.pre_rollback = pre_rollback
        self.post_rollback = post_rollback

        hasher = hashlib.sha256()
        def update_hash(command):
            if command is None:
                hasher.update(b'')
                return
            hasher.update(hash(tuple(command)).to_bytes(8, 'little', signed=True))
        update_hash(command)
        update_hash(rollback_command)
        update_hash(pre_install)
        update_hash(post_install)
        update_hash(pre_rollback)
        update_hash(post_rollback)
        self.hash = hasher.hexdigest()

    def declare(self, cursor):
        cursor.execute(
            '''
                INSERT OR IGNORE
                INTO step (name, priority, hash)
                VALUES (?, ?, ?)
            ''',
            (self.name, self.priority, self.hash),
        )

    def enact(self, conn):
        self.record_status(conn, 'in-progress')

        if self.pre_install is not None:
            for command in self.pre_install:
                if type(command) is str:
                    command = shlex.split(command)
                if type(command) is System:
                    command.run()
                else:
                    self.execute(command)

        self.execute(self.command)

        if self.post_install is not None:
            for command in self.post_install:
                if type(command) is str:
                    command = shlex.split(command)
                if type(command) is System:
                    command.run()
                else:
                    self.execute(command)

        self.record_status(conn, 'complete')

    def rollback(self, conn):
        if self.rollback_command is None:
            raise Exception(f'cannot rollback {self.command}')

        if self.pre_rollback is not None:
            for command in self.pre_rollback:
                if type(command) is str:
                    command = shlex.split(command)
                if type(command) is System:
                    command.run()
                else:
                    self.execute(command)

        self.execute(self.rollback_command)

        if self.post_rollback is not None:
            for command in self.post_rollback:
                if type(command) is str:
                    command = shlex.split(command)
                if type(command) is System:
                    command.run()
                else:
                    self.execute(command)

        self.record_status(conn, 'not-started')

    def execute(self, command):
        print(f'$ {' '.join(command)}')
        if DRY_RUN:
            return
        subprocess.run(command).check_returncode()

    def record_status(self, conn, status):
        statuses = {
            'not-started': 0,
            'in-progress': 1,
            'complete': 2,
        }
        status = statuses[status]
        try:
            cursor = conn.cursor()
            cursor.execute('BEGIN IMMEDIATE')
            cursor.execute(
                '''
                    UPDATE step
                    SET status = ?
                    WHERE name = ?
                ''',
                (status, self.name)
            )
            cursor.execute('COMMIT')
        except Exception as ex:
            cursor.execute('ROLLBACK')
            raise ex

PRIORITY_PRE = -99999
PRIORITY_POST = 99999

PRIORITY_APT = 0 * 8
def apt(name, **kwargs):
    return Command(
        name,
        ['sudo', 'apt', 'install', '-y', name],
        PRIORITY_APT,
        rollback_command=['sudo', 'apt', 'remove', '-y', name],
        **kwargs,
    )

PRIORITY_SNAP = 1 * 8
def snap(name, **kwargs):
    return Command(
        name,
        ['sudo', 'snap', 'install', name],
        PRIORITY_SNAP,
        rollback_command=['sudo', 'snap', 'remove', '--purge', name],
        **kwargs
    )

PRIORITY_CLASSIC_SNAP = 2 * 8
def classic_snap(name, **kwargs):
    return Command(
        name,
        ['sudo', 'snap', 'install', '--classic', name],
        PRIORITY_CLASSIC_SNAP,
        rollback_command=['sudo', 'snap', 'remove', '--purge', name],
        **kwargs
    )

PRIORITY_CARGO = 3 * 8
def cargo(name, **kwargs):
    return Command(
        name,
        ['cargo', 'install', '--locked', name],
        PRIORITY_CARGO,
        rollback_command=['cargo', 'uninstall', name],
        **kwargs
    )

PRIORITY_DOTDIR = 4 * 8
def dotdir(dir, **kwargs):
    dir = dir.removesuffix('/')
    source_dir = os.path.abspath(f'./home/{dir}')
    absdir = os.path.expanduser(f'~/{dir}')
    return Command(
        dir,
        ['ln', '-fs', source_dir, absdir],
        PRIORITY_DOTDIR,
        **kwargs,
    )

PRIORITY_DOTFILE = 5 * 8
def dotfile(file, source_file=None, copy=False, **kwargs):
    if source_file is None:
        source_file = os.path.abspath(f'./home/{file}')
    absfile = os.path.expanduser(f'~/{file}')
    parent = Path(absfile).parent

    shell_command = None
    if copy:
        shell_command = ['cp', source_file, absfile]
    else:
        shell_command = ['ln', '-fs', source_file, absfile]
    return Command(
        file,
        shell_command,
        PRIORITY_DOTFILE,
        pre_install=f'mkdir -p {parent}',
        **kwargs,
    )

CLEANUP_PRIOIRTY = 10000 * 8
def cleanup(command):
    name = ' '.join(command)
    return Command(
        name,
        command,
        CLEANUP_PRIOIRTY,
        rollback_command=['echo', 'skipping', 'cleanup', 'rollback'],
    )

def main():
    conn = ensure_setup('dotfiles.db')

    machine_info = MachineInfo(conn)

    tasks = all_tasks(machine_info)
    populate_tasks(conn, tasks)

    tasks_by_name = { task.name: task for task in tasks }

    cursor = conn.cursor()
    to_rollback_query = cursor.execute('''
        SELECT name
        FROM step
        WHERE status = 1
        ORDER BY
            priority ASC,
            name ASC
    ''')
    to_rollback = [ tasks_by_name[name] for (name,) in to_rollback_query ]
    for task in to_rollback:
        task.rollback(conn)

    to_enact_query = cursor.execute('''
        SELECT name
        FROM step
        WHERE status = 0
        ORDER BY
            priority ASC,
            name ASC
    ''')
    to_enact = [ tasks_by_name[name] for (name,) in to_enact_query ]
    for task in to_enact:
        task.enact(conn)

class MachineInfo:
    def __init__(self, conn):
        cursor = conn.cursor()

        machine_info_query = cursor.execute('''
            SELECT key, value
            FROM machine_info
        ''')
        machine_info = { key: value for (key,value) in machine_info_query }
        self.__dict__.update(self.fill_in_missing(conn, machine_info))

    def fill_in_missing(self, conn, machine_info: dict):
        machine_info = copy.deepcopy(machine_info)

        cursor = conn.cursor()

        cursor.execute('BEGIN')

        if 'host_name' not in machine_info:
            self.record('host_name', cursor, machine_info, socket.gethostname())
        if 'work_device' not in machine_info:
            value = self.prompt('is this a work device? [y/n]', transform=transform_yn_bool)
            self.record('work_device', cursor, machine_info, value)
        if 'bells_and_whistles' not in machine_info:
            value = self.prompt('add the bells and whistles? [y/n]', transform=transform_yn_bool)
            self.record('bells_and_whistles', cursor, machine_info, value)
        if 'portable' not in machine_info:
            value = self.prompt('is this device portable? [y/n]', transform=transform_yn_bool)
            self.record('portable', cursor, machine_info, value)
        if 'gaming' not in machine_info:
            value = self.prompt('is this a gaming device? [y/n]', transform=transform_yn_bool)
            self.record('gaming', cursor, machine_info, value)

        cursor.execute('COMMIT')

        return machine_info

    def prompt(self, challenge, transform=None):
        value = input(f'{challenge}: ')
        if value == '':
            raise Exception('abort')
        if transform is not None:
            value = transform(value)
        return value

    def record(self, key, cursor, machine_info, value):
        cursor.execute(
            '''
                INSERT OR REPLACE
                INTO machine_info (key, value)
                VALUES (?, ?)
            ''',
            (key, value),
        )
        machine_info[key] = value

def transform_yn_bool(yn: str) -> bool:
    yn = yn.lower()
    if yn in ['y', 'ye', 'yes']:
        return True
    if yn in ['n', 'no']:
        return False
    raise Exception(f'expected y/n, got {yn}')

def all_tasks(machine_info: MachineInfo):
    unsorted_tasks = []
    def declare(cmd):
        unsorted_tasks.append(cmd)

    declare(Command(
        'apt update',
        ['sudo', 'apt', 'update', '-y'],
        PRIORITY_PRE,
    ))
    declare(Command(
        'apt upgrade',
        ['sudo', 'apt', 'upgrade', '-y'],
        PRIORITY_PRE + 1,
    ))
    declare(Command(
        'add-apt-repository',
        ['sudo', 'add-apt-repository', '-y', 'universe'],
        PRIORITY_PRE + 2,
    ))
    declare(apt('curl'))
    declare(apt('fonts-firacode'))

    if machine_info.bells_and_whistles:
        declare(apt('eza'))

    fish_post_install = None
    if machine_info.host_name not in ['dirk']:
        fish_post_install = 'chsh -s /usr/bin/fish'
    declare(apt(
        'fish',
        post_install=fish_post_install,
    ))

    declare(apt('gcc'))
    declare(apt(
        'git',
        post_install=[
            # 'gpg --full-generate-key'
            # TODO(kcza): make a dialogue to select the right key, then
            # gpg --armor --export <key> into the clipboard
            # git config --global user.signingkey <key>
        ],
    ))
    declare(apt('gnome-tweaks'))
    declare(apt('golang-go'))
    declare(apt('luajit'))
    declare(apt('luarocks'))
    declare(apt('make'))
    declare(apt(
        'mullvad-vpn',
        pre_install=[
            'sudo curl -fsSLo /usr/share/keyrings/mullvad-keyring.asc https://repository.mullvad.net/deb/mullvad-keyring.asc',
            System('echo "deb [signed-by=/usr/share/keyrings/mullvad-keyring.asc arch=$( dpkg --print-architecture )] https://repository.mullvad.net/deb/stable stable main" | sudo tee /etc/apt/sources.list.d/mullvad.list'),
            'sudo apt update',
        ],
        # requires='curl'
    ))
    declare(apt(
        'libnvidia-gl-590:i386',
        pre_install=[
            'sudo dpkg --add-architecture i386',
            'sudo apt update',
        ],
    ))
    declare(apt(
        'plocate',
        post_install='sudo updatedb',
    ))
    declare(apt('ripgrep'))
    declare(apt('sqlite3'))
    if machine_info.portable:
        declare(apt('tlp'))
    declare(apt('tree'))
    declare(apt(
        'wezterm',
        pre_install=[
            System("curl -fsSL https://apt.fury.io/wez/gpg.key | sudo gpg --yes --dearmor -o /usr/share/keyrings/wezterm-fury.gpg"),
            System("echo 'deb [signed-by=/usr/share/keyrings/wezterm-fury.gpg] https://apt.fury.io/wez/ * *' | sudo tee /etc/apt/sources.list.d/wezterm.list"),
            "sudo chmod 644 /usr/share/keyrings/wezterm-fury.gpg",
            "sudo apt update",
        ],
    ))
    declare(snap('brave'))
    declare(snap('discord'))
    declare(snap('gedit'))
    declare(snap('mergiraf'))
    # declare(snap(
    #     'obs-studio',
    #     post_install=[
    #         "sudo snap connect obs-studio:kernel-module-observe",
    #         "sudo snap connect obs-studio:screencast-legacy",
    #         "sudo apt -y install v4l2loopback-dkms v4l2loopback-utils",
    #         "echo 'options v4l2loopback devices=1 video_nr=13 card_label=\"OBS Virtual Camera\" exclusive_caps=1' | sudo tee /etc/modprobe.d/v4l2loopback.conf",
    #         "echo \"v4l2loopback\" | sudo tee /etc/modules-load.d/v4l2loopback.conf",
    #         "sudo modprobe -r v4l2loopback",
    #         "sudo modprobe v4l2loopback devices=1 video_nr=13 card_label=\"OBS Virtual Camera\" exclusive_caps=1",
    #     ],
    # ))
    if machine_info.gaming:
        declare(snap('steam'))
    declare(snap(
        'yuescript',
        post_install='sudo snap alias yuescript.yue yue'
    ))
    declare(classic_snap('gh'))
    declare(classic_snap(
        'rustup',
        post_install='rustup toolchain install stable',
    ))
    declare(classic_snap('nvim'))
    declare(cargo('bottom'))
    declare(cargo('cargo-nextest'))
    declare(cargo('fd-find'))
    declare(cargo('forgejo-cli'))
    declare(cargo('jj-cli'))
    declare(cargo('prek'))
    declare(cargo('starship'))
    declare(dotdir('.config/starship/'))
    declare(dotfile('.config/starship.toml'))
    declare(dotfile('.config/jj/config.toml'))
    declare(dotdir(
        '.config/nvim/',
        pre_install='yue home/.config/nvim/',
    ))
    declare(dotdir(
        '.config/wezterm/',
        pre_install='yue home/.config/wezterm/',
    ))
    declare(dotfile('.config/fish/config.fish'))
    declare(dotfile(
        '.wezterm.lua',
        source_file='home/.config/wezterm/.wezterm.lua',
    ))
    # declare(font())
    # TODO(kcza): mpv (install sync-city as a pre-command)
    # TODO(kcza): figure out how to install the font, `fc-cache -fv`?
    # TODO(kcza): encrypt the fonts with gpg to avoid copyright issues.
    declare(cleanup(['sudo', 'apt', 'autoremove']))

    if machine_info.work_device:
        declare(snap('matterhorn'))
        # TODO(kcza): add config.ini and theme.ini here
        declare(dotfile('snap/matterhorn/current/.config/matterhorn/config.ini', copy=True))
        declare(dotfile('snap/matterhorn/current/.config/matterhorn/theme.ini', copy=True))

    sorted_tasks = unsorted_tasks # TODO(kcza): DFS down the dependencies.
    return sorted_tasks
    # TODO(kcza): add additional commands / extension tables for:
    # - Post-commands
    #   - git setup
    # - Pre-commands
    #   - Setup keyrings and apt thingies

class System:
    def __init__(self, command):
        self.command = command

    def run(self):
        subprocess.run(self.command, shell=True).check_returncode()

    def __hash__(self):
        return hash(self.command)

def ensure_setup(db_path):
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    try:
        cursor.executescript('''
            PRAGMA foreign_keys = ON;
        ''')

        cursor.execute('BEGIN IMMEDIATE')

        query = cursor.execute('PRAGMA user_version')
        user_version = cursor.fetchone()[0]
        if user_version == 0:
            cursor.executescript(SCHEMA)
        elif user_version != VERSION:
            raise Exception(f'db at {db_path} incompatible, delete then retry')

        cursor.execute('COMMIT')
    except Exception as ex:
        cursor.execute('ROLLBACK')
        raise ex

    return conn

def populate_tasks(conn, tasks):
    cursor = conn.cursor()
    try:
        conn.execute('BEGIN')
        for task in tasks:
            task.declare(cursor)
        cursor.execute('COMMIT')
    except Exception as ex:
        cursor.execute('ROLLBACK')
        raise ex

if __name__ == '__main__':
    main()
