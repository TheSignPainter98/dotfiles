class System:
    def __init__(self, command):
        self.command = command

    def run(self):
        subprocess.run(self.command, shell=True).check_returncode()

    def __hash__(self):
        return hash(self.command)

def ensure_setup(db_path, tasks):
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    try:
        cursor.executescript('''
            PRAGMA foreign_keys = ON;
        ''')

        cursor.execute('BEGIN IMMEDIATE')

        query = cursor.execute('PRAGMA user_version')
        user_version = cursor.fetchone()[0]
        if user_version == 0:
            cursor.executescript(SCHEMA)
        elif user_version != VERSION:
            raise Exception(f'db at {db_path} incompatible, delete then retry')

        for task in tasks:
            task.declare(cursor)
        cursor.execute('COMMIT')
    except Exception as ex:
        cursor.execute('ROLLBACK')
        raise ex

    return conn

if __name__ == '__main__':
    main()
